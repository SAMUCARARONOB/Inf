        noParticles = state

        if state then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ParticleEmitter") or v:IsA("Trail") then
                    savedEffects[v] = v.Enabled
                    v.Enabled = false
                end
            end
        else
            for v, enabled in pairs(savedEffects) do
                if v then
                    v.Enabled = enabled
                end
            end
        end
    end
