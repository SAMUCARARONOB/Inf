-- =========================

local fpsBoost = false

Window:CreateToggle("SETTING", {
    Text = "FPS BOOST",
    Default = false,
    Callback = function(state)
        fpsBoost = state

        if state then
            Lighting.GlobalShadows = false
            Lighting.FogEnd = 1e10

            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("BasePart") then
                    if not savedParts[v] then
                        savedParts[v] = {
                            Material = v.Material,
                            Reflectance = v.Reflectance
                        }
                    end
                    v.Material = Enum.Material.Plastic
                    v.Reflectance = 0
                elseif v:IsA("Decal") or v:IsA("Texture") then
                    if not savedEffects[v] then
                        savedEffects[v] = v.Transparency
                    end
                    v.Transparency = 1
                end
            end

        else
            Lighting.GlobalShadows = original.GlobalShadows
            Lighting.FogEnd = original.FogEnd

            for v, data in pairs(savedParts) do
                if v then
                    v.Material = data.Material
                    v.Reflectance = data.Reflectance
                end
            end

            for v, trans in pairs(savedEffects) do
                if v then
                    v.Transparency = trans
                end
            end
        end
    end
})

