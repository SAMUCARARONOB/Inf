local noAnim = false
local savedAnimators = {}

Window:CreateToggle("SETTING", {
    Text = "REMOVER ANIMAÇÕES",
    Default = false,
    Callback = function(state)
        noAnim = state

        if state and LocalPlayer.Character then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("Animator") then
                    table.insert(savedAnimators, v:Clone())
                    v:Destroy()
                end
            end
        elseif not state and LocalPlayer.Character then
            for _, anim in pairs(savedAnimators) do
                anim.Parent = LocalPlayer.Character:FindFirstChild("Humanoid")
            end
            savedAnimators = {}
        end
    end
})

